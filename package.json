{
	"name": "sexy-tui-rs",
	"version": "0.1.0",
	"description": "Forked TUI library — sexy terminal UI with differential rendering",
	"type": "module",
	"main": "dist/index.js",
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"test": "node --test test/*.test.ts",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"files": [
		"dist/**/*",
		"native/win32/prebuilds/**/*.node",
		"native/darwin/prebuilds/**/*.node",
		"README.md"
	],
	"keywords": [
		"tui",
		"terminal",
		"ui",
		"text-editor",
		"differential-rendering",
		"typescript",
		"cli"
	],
	"author": "Mario Zechner",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/skaft/sexy-tui-rs.git"
	},
	"engines": {
		"node": ">=22.19.0"
	},
	"types": "./dist/index.d.ts",
	"dependencies": {
		"get-east-asian-width": "1.6.0",
		"marked": "15.0.12"
	},
	"devDependencies": {
		"@xterm/headless": "5.5.0",
		"chalk": "5.6.2"
	}
}
